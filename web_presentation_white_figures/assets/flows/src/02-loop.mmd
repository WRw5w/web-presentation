flowchart TD
    A["loop：持续、自动化、全自主训练；不能中途停止"]
    B["采用 Codex 开发路线"]
    C["尝试使用 Codex Goal<br/>让线程/任务持续存在"]
    D["问题：Goal 在当前 turn 没有工作后会自动续一次<br/>它不适合在未来某个离散时刻才访问"]
    E["例：每小时打一次榜<br/>却可能在这一小时内持续轮询"]
    F["Token 被吃光，不能作为方案"]

    A --> B --> C --> D --> E --> F

    subgraph H["时间驱动线：Heartbeat"]
      H1["官方 Heartbeat：到时间触发一次"]
      H2["适合定期检查长期任务<br/>检查退出信号、错误、下载、状态是否正确"]
      H3["风险：模型可能摆烂/只看浅层信号<br/>漏掉实际报错或异常状态"]
      H4["改进：在 Heartbeat 提示词中强化<br/>要求读取持久状态、日志、退出原因、回执"]
      H5["问题: 效率太低,一分钟就报错了不去修,等到一个小时闹钟响声了才去修"]
      H1 --> H2 --> H3 --> H4 --> H5
    end

    subgraph W["事件驱动线：TaskWatcher"]
      W1["监听任务/训练进程 PID"]
      W2["PID 结束或状态变化"]
      W3["旧实现的问题：只返回结果<br/>没有开启新的 turn / 对话流程"]
      W4["结果：模型没有被唤醒<br/>任务事件无人处理，流程死亡"]
      W5["改进：Windows 常驻事件监听器<br/>调用 OpenAI 暴露的“开启新 turn”接口"]
      W6["可在事件到来时拉起新的处理 turn"]
      W7["局限：它主要捕捉线程结束；<br/>下载停滞、错误语义、未正常完成等仍需进一步判断"]
      W1 --> W2 --> W3 --> W4 --> W5 --> W6 --> W7
    end

    F --> H1
    F --> W1

    H5 --> X["组合策略"]
    W7 --> X

    X["组合策略：<br/>Heartbeat 低频、定期、深入地核对任务真实状态；<br/>TaskWatcher 对短任务与 PID 结束提供快速事件反馈"]
    X --> Y["仍受独立的‘调度器是否真的拉起新 turn’问题限制"]
